# ============================================================
# Prospec-o-Ativa — Configuração de chaves de API
# ============================================================
# INSTRUÇÕES:
#   1. Copie este arquivo para ".env":  cp .env.example .env
#   2. Preencha as chaves abaixo
#   3. NUNCA suba o arquivo .env para o Git
# ============================================================

# ── Google Maps Places API ───────────────────────────────────
# Necessário para o comando: python main.py maps
#
# Como obter (GRATUITO até ~5.000 buscas/mês com o crédito de US$200):
#   1. Acesse: https://console.cloud.google.com/
#   2. Crie um projeto (ou use um existente)
#   3. Ative a API "Places API" em "APIs e Serviços"
#   4. Vá em "Credenciais" > "Criar credencial" > "Chave de API"
#   5. Cole a chave abaixo
#
GOOGLE_MAPS_API_KEY=SUA_CHAVE_AQUI


# ── Brasil.io (busca por CNPJ/CNAE) ─────────────────────────
# Necessário para o comando: python main.py cnpj
# TOTALMENTE GRATUITO — basta criar conta.
#
# Como obter:
#   1. Crie conta gratuita em: https://brasil.io/
#   2. Acesse: https://brasil.io/auth/tokens-api/
#   3. Gere um token e cole abaixo
#
BRASILIO_TOKEN=SEU_TOKEN_AQUI
